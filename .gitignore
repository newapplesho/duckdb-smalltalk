# Pharo image + VM (installed separately into pharo-local/ — see README)
/pharo-local/

# DuckDB native library — downloaded per platform; only README.md is tracked
/lib/*
!/lib/README.md

# Pharo caches
/package-cache/
/play-cache/
/play-stash/
/github-cache/
github-*.zip

# Smalltalk debug logs
PharoDebug.log
SqueakDebug.log

# Test output at repository root
/*-Test.xml
/progress.log

# Image / changes (if Pharo is ever run outside pharo-local/)
*.image
*.changes
*.sources

# IDE / OS
.idea/
*.swp
.DS_Store
